# Copy to docker/.env and customize, then run from the docker/ directory:
#   docker compose up --build
#   docker compose --profile ollama up --build   # also start a local Ollama server

VISIONIQ_EMBEDDING_DEFAULT=dummy
VISIONIQ_REASONING_PROVIDER=template

VISIONIQ_OLLAMA_MODEL=llama3.2

VISIONIQ_OPENAI_API_KEY=
VISIONIQ_OPENAI_BASE_URL=https://api.openai.com/v1
VISIONIQ_OPENAI_MODEL=gpt-4o-mini

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
