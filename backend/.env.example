VISIONIQ_EMBEDDING_DEFAULT=dummy
VISIONIQ_REASONING_PROVIDER=template

VISIONIQ_VECTOR_STORE_DIR=data/vector_store
VISIONIQ_DATABASE_URL=sqlite:///./data/visioniq.db

VISIONIQ_CORS_ORIGINS=["http://localhost:3000"]

# Used when VISIONIQ_REASONING_PROVIDER=ollama
VISIONIQ_OLLAMA_HOST=http://localhost:11434
VISIONIQ_OLLAMA_MODEL=llama3.2

# Used when VISIONIQ_REASONING_PROVIDER=openai_compatible
VISIONIQ_OPENAI_API_KEY=
VISIONIQ_OPENAI_BASE_URL=https://api.openai.com/v1
VISIONIQ_OPENAI_MODEL=gpt-4o-mini
